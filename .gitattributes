# Normalize line endings across the repository
* text=auto

# Keep source and config files on LF for cross-platform consistency
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Keep Windows scripts as CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
